# Rust / Tauri
src-tauri/target/

# Generated icon variants. Only the source icon.png is committed;
# `pnpm tauri icon src-tauri/icons/icon.png` regenerates the rest
# (32x32.png, 128x128.png, 128x128@2x.png, icon.icns, icon.ico) at
# build time. Keeping them out of git avoids committing binary blobs
# that drift from the source.
src-tauri/icons/32x32.png
src-tauri/icons/128x128.png
src-tauri/icons/128x128@2x.png
src-tauri/icons/icon.icns
src-tauri/icons/icon.ico
src-tauri/icons/Square*.png
src-tauri/icons/StoreLogo.png

# Tauri build metadata
src-tauri/gen/
